# ── AWS RDS / PostgreSQL connection ──────────────────────────────────────────
# Option A: provide a full connection URL (takes priority)
DATABASE_URL=postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>

# Option B: individual fields (used when DATABASE_URL is not set)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=securevault
DB_USER=postgres
DB_PASSWORD=your_db_password

# Set DB_SSL=false only for local development without SSL
# DB_SSL=false

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# Email settings for OTP (optional — if not set, OTP is printed to console in dev mode)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend origin for CORS (optional — defaults to allow all origins)
CLIENT_URL=https://your-app.onrender.com

# Port (set automatically by Render — do not change)
# PORT=5000
