# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/securevault?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# Email settings for OTP (optional — if not set, OTP is printed to console in dev mode)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend origin for CORS (optional — defaults to *)
CLIENT_URL=https://your-app.onrender.com

# Port (set automatically by Render — do not change)
# PORT=5000
