# ── Database (AWS RDS) ──
DB_HOST=REPLACE_ME_RDS_ENDPOINT
DB_USER=REPLACE_ME_DB_USER
DB_PASS=REPLACE_ME_DB_PASSWORD
DB_NAME=securevault
DB_PORT=3306

# ── JWT ──
JWT_SECRET=REPLACE_ME_STRONG_RANDOM_SECRET

# ── Server ──
PORT=4000
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_MB=10

# ── AWS S3 ──
AWS_ACCESS_KEY=REPLACE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_KEY=REPLACE_ME_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=REPLACE_ME_UNIQUE_BUCKET_NAME

# Optional (recommended): 32-byte encryption key for server-side AES-256-GCM before S3 upload
# Supports: 64-char hex, base64(32-byte), or raw 32-char text
FILE_ENCRYPTION_KEY=REPLACE_ME_32_BYTE_KEY
