# ── Database (AWS RDS) ──
DB_HOST=securevault.cktwky6849sx.us-east-1.rds.amazonaws.com
DB_USER=admin
DB_PASS=<your-db-password>
DB_NAME=securevault
DB_PORT=3306

# ── JWT ──
JWT_SECRET=<generate-a-strong-random-secret>

# ── Server ──
PORT=4000
# Set this to your deployed frontend URL (no trailing slash).
# For multiple origins (e.g. production + preview), separate with commas:
#   CORS_ORIGIN=https://secure-vault-og.vercel.app,https://secure-vault-preview.vercel.app
CORS_ORIGIN=https://secure-vault-og.vercel.app
MAX_UPLOAD_MB=10

# ── AWS S3 ──
AWS_ACCESS_KEY=<your-aws-access-key>
AWS_SECRET_KEY=<your-aws-secret-key>
AWS_REGION=us-east-1
AWS_BUCKET_NAME=securevault-registry

# Optional (recommended): 32-byte encryption key for server-side AES-256-GCM before S3 upload
# Supports: 64-char hex, base64(32-byte), or raw 32-char text
FILE_ENCRYPTION_KEY=<generate-a-64-char-hex-key>

# ── Email / SMTP (for welcome emails and password-reset OTPs) ──
# Gmail example: use an App Password (not your normal Gmail password).
# Enable 2FA on your Google account, then go to:
#   https://myaccount.google.com/apppasswords → create an "App Password".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=<your-gmail-app-password>
