# ── Database (AWS RDS) ──
DB_HOST=your-rds-endpoint
DB_USER=your-db-user
DB_PASS=your-db-password
DB_NAME=securevault
DB_PORT=3306

# ── JWT ──
JWT_SECRET=replace-with-a-strong-random-secret

# ── Server ──
PORT=4000
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_MB=10

# ── AWS S3 ──
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=securevault-storage-unique-name

# Optional (recommended): 32-byte encryption key for server-side AES-256-GCM before S3 upload
# Supports: 64-char hex, base64(32-byte), or raw 32-char text
FILE_ENCRYPTION_KEY=replace-with-32-byte-key
